{
  "expo": {
    "name": "Cerlita Chat",
    "slug": "cerlita-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.jpg",
    "scheme": "cerlitachat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#FF69B4",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cerlita.chat",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Cerlita Chat needs access to your camera to send photos and videos to your chats.",
        "NSPhotoLibraryUsageDescription": "Cerlita Chat needs access to your photos to share them in chats.",
        "NSPhotoLibraryAddUsageDescription": "Cerlita Chat needs to save shared media to your library.",
        "NSMicrophoneUsageDescription": "Cerlita Chat needs access to your microphone to record audio messages and make calls.",
        "UIBackgroundModes": ["remote-notification", "voip"]
      },
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF69B4"
      },
      "package": "com.cerlita.chat",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.WAKE_LOCK"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-camera",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Cerlita Chat needs access to your photos to share them in chats.",
          "cameraPermission": "Cerlita Chat needs access to your camera to send photos and videos."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Cerlita Chat needs access to your microphone to record audio messages and make calls."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Cerlita Chat needs access to your photo library.",
          "savePhotosPermission": "Cerlita Chat needs to save media to your library.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
